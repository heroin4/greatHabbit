.profile-card {
  align-items: center;
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.avatar {
  align-items: center;
  background: #eefaf4;
  border-radius: 30rpx;
  display: flex;
  font-size: 56rpx;
  height: 110rpx;
  justify-content: center;
  width: 110rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
}

.todo {
  border-top: 1rpx solid #eeeeF6;
  color: #4b4b66;
  font-size: 30rpx;
  padding: 22rpx 0;
}


.subscribe-button {
  margin-top: 24rpx;
}
