.edit-hero {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(232, 249, 245, 0.82));
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #21b6a8;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.18;
  margin-bottom: 12rpx;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.label {
  color: #4b4b66;
  font-size: 26rpx;
  font-weight: 800;
  margin-top: 12rpx;
}

.inline-grid {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
}

.input,
.picker {
  background: rgba(247, 247, 251, 0.92);
  border: 1rpx solid rgba(108, 99, 255, 0.1);
  border-radius: 22rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  font-size: 30rpx;
  padding: 24rpx;
}

.save-button {
  margin-top: 34rpx;
}
