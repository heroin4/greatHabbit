.stats-hero {
  background: linear-gradient(135deg, rgba(32, 32, 51, 0.96), rgba(108, 99, 255, 0.9));
  color: #ffffff;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.stats-hero::after {
  background: radial-gradient(circle, rgba(255, 255, 255, 0.22), transparent 62%);
  content: "";
  height: 260rpx;
  position: absolute;
  right: -80rpx;
  top: -80rpx;
  width: 260rpx;
}

.eyebrow {
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 46rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.stats-hero .muted {
  color: rgba(255, 255, 255, 0.76);
}

.grid {
  display: grid;
  gap: 22rpx;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 24rpx;
}

.metric {
  min-height: 190rpx;
}

.metric-icon {
  font-size: 42rpx;
  margin-bottom: 18rpx;
}

.metric-value {
  color: #6c63ff;
  font-size: 52rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.list-card {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 36rpx;
  font-weight: 900;
  margin-bottom: 18rpx;
}

.stat-row {
  align-items: center;
  border-top: 1rpx solid rgba(125, 126, 150, 0.13);
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
}

.stat-row:first-of-type {
  border-top: 0;
}

.stat-left {
  align-items: center;
  display: flex;
  gap: 18rpx;
}

.mini-icon {
  align-items: center;
  border-radius: 20rpx;
  display: flex;
  font-size: 34rpx;
  height: 72rpx;
  justify-content: center;
  width: 72rpx;
}

.habit-name {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.total {
  color: #202033;
  font-size: 30rpx;
  font-weight: 900;
}

.reward-preview {
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 252, 246, 0.94), rgba(240, 247, 255, 0.92));
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.reward-count {
  align-items: center;
  background: #15172f;
  border-radius: 30rpx;
  color: #8cf6df;
  display: flex;
  font-size: 44rpx;
  font-weight: 900;
  height: 104rpx;
  justify-content: center;
  width: 104rpx;
}

.metric.highlight {
  background: linear-gradient(135deg, rgba(246, 250, 255, 0.98), rgba(236, 232, 255, 0.94));
}
