<view class="container today-shell">
  <view class="aurora aurora-one"></view>
  <view class="aurora aurora-two"></view>
  <view class="hero card">
    <view class="hero-bg"></view>
    <view class="hero-top">
      <view class="hero-copy">
        <view class="eyebrow">{{today}} · {{appMeta.visualVersion}}</view>
        <view class="title">把今天过成喜欢的样子</view>
        <view class="hero-subtitle">{{appMeta.buildLabel}}，持续一点。</view>
      </view>
      <view class="date-orb">
        <view class="orb-day">{{completedCount}}</view>
        <view class="orb-label">DONE</view>
      </view>
    </view>
    <view class="progress-wrap">
      <view class="progress-info">
        <text>今日完成</text>
        <text>{{completedCount}} / {{habits.length}}</text>
      </view>
      <view class="progress-track">
        <view class="progress-bar" style="width: {{progressPercent}}%"></view>
      </view>
    </view>
    <view class="hero-actions">
      <button class="hero-cta" bindtap="goCreate">＋ 添加新习惯</button>
      <view class="hero-chip">🌿 温和提醒</view>
    </view>
  </view>

  <view class="section-header">
    <view>
      <view class="section-title">今日节奏</view>
      <view class="muted">按下完成，记录真实投入。</view>
    </view>
    <view class="pulse-dot"></view>
  </view>

  <view class="habit-list">
    <view wx:for="{{habits}}" wx:key="id" class="habit card {{item.log ? 'is-done' : ''}}">
      <view class="habit-accent" style="background: {{item.color}}"></view>
      <view class="habit-main">
        <view class="icon" style="background: {{item.color}}22; color: {{item.color}}">{{item.icon}}</view>
        <view class="habit-copy">
          <view class="habit-name">{{item.name}}</view>
          <view class="habit-meta">
            <text>目标 {{item.targetValue}}{{item.unit}}</text>
            <text class="dot">·</text>
            <text>{{item.reminderTime}} 提醒</text>
          </view>
        </view>
      </view>
      <view wx:if="{{item.log}}" class="done-pill">✓ {{item.log.value}}{{item.unit}}</view>
      <button wx:else class="primary-button record-button" data-id="{{item.id}}" bindtap="recordHabit">完成</button>
    </view>
  </view>
</view>
