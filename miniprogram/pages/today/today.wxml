<view class="container">
  <view class="hero card">
    <view>
      <view class="eyebrow">{{today}}</view>
      <view class="title">今天要做什么？</view>
      <view class="muted">完成 {{completedCount}} / {{habits.length}} 个习惯</view>
    </view>
    <button class="add-button" bindtap="goCreate">＋</button>
  </view>

  <view class="habit-list">
    <view wx:for="{{habits}}" wx:key="id" class="habit card {{item.log ? 'is-done' : ''}}">
      <view class="habit-main">
        <view class="icon" style="background: {{item.color}}22; color: {{item.color}}">{{item.icon}}</view>
        <view class="habit-copy">
          <view class="habit-name">{{item.name}}</view>
          <view class="muted">目标 {{item.targetValue}}{{item.unit}} · {{item.reminderTime}} 提醒</view>
        </view>
      </view>
      <view wx:if="{{item.log}}" class="done-pill">已记录 {{item.log.value}}{{item.unit}}</view>
      <button wx:else class="primary-button record-button" data-id="{{item.id}}" bindtap="recordHabit">完成</button>
    </view>
  </view>
</view>
