.today-shell {
  background: linear-gradient(180deg, #f7ead4 0%, #f5efe5 38%, #e9eefc 100%);
  color: #202033;
}

.sun-glow {
  background: radial-gradient(circle, rgba(255, 198, 96, 0.7), rgba(255, 198, 96, 0));
  height: 420rpx;
  left: -130rpx;
  position: absolute;
  top: -160rpx;
  width: 420rpx;
  z-index: 0;
}

.tech-grid {
  background-image: linear-gradient(rgba(108, 99, 255, 0.08) 1rpx, transparent 1rpx), linear-gradient(90deg, rgba(108, 99, 255, 0.08) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  height: 520rpx;
  opacity: 0.8;
  position: absolute;
  right: -40rpx;
  top: 80rpx;
  transform: rotate(-8deg);
  width: 520rpx;
  z-index: 0;
}

.dashboard {
  background: linear-gradient(145deg, rgba(255, 252, 246, 0.96), rgba(242, 246, 255, 0.9));
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  margin-bottom: 34rpx;
  overflow: hidden;
}

.dashboard::after {
  background: linear-gradient(135deg, rgba(108, 99, 255, 0.16), rgba(33, 182, 168, 0.16));
  border-radius: 50%;
  content: "";
  height: 300rpx;
  position: absolute;
  right: -100rpx;
  top: -100rpx;
  width: 300rpx;
}

.dashboard-top {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.eyebrow {
  color: #6c63ff;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
}

.title {
  color: #171a33;
  font-size: 58rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
  line-height: 1.08;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  color: #7c746c;
  font-size: 27rpx;
  line-height: 1.55;
  max-width: 460rpx;
}

.score-orb {
  align-items: center;
  background: #15172f;
  border-radius: 36rpx;
  box-shadow: 0 24rpx 52rpx rgba(21, 23, 47, 0.24);
  color: #ffffff;
  display: flex;
  flex-direction: column;
  height: 132rpx;
  justify-content: center;
  position: relative;
  width: 132rpx;
  z-index: 1;
}

.score-number {
  color: #8cf6df;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.score-label {
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  margin-top: 10rpx;
}

.progress-panel {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  margin-top: 42rpx;
  padding: 22rpx;
  position: relative;
  z-index: 1;
}

.progress-info {
  color: #4d4f68;
  display: flex;
  font-size: 26rpx;
  font-weight: 900;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-track {
  background: rgba(21, 23, 47, 0.08);
  border-radius: 999rpx;
  height: 22rpx;
  overflow: hidden;
}

.progress-bar {
  background: linear-gradient(90deg, #15172f, #6c63ff, #21b6a8);
  border-radius: 999rpx;
  height: 100%;
  transition: width 0.25s ease;
}

.quick-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr 1.2fr;
  margin-top: 18rpx;
  position: relative;
  z-index: 1;
}

.quick-card,
.quick-add {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 26rpx;
  color: #202033;
  min-height: 104rpx;
  padding: 18rpx;
}

.quick-value {
  font-size: 34rpx;
  margin-bottom: 8rpx;
}

.quick-label {
  color: #6b665f;
  font-size: 23rpx;
  font-weight: 800;
}

.quick-add {
  align-items: center;
  background: linear-gradient(135deg, #15172f, #6c63ff);
  color: #ffffff;
  display: flex;
  font-size: 27rpx;
  font-weight: 900;
  justify-content: center;
  line-height: 1.2;
  margin: 0;
}

.section-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 8rpx 4rpx 22rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  color: #171a33;
  font-size: 38rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.pulse-dot {
  background: #21b6a8;
  border-radius: 50%;
  box-shadow: 0 0 0 12rpx rgba(33, 182, 168, 0.16), 0 0 36rpx rgba(33, 182, 168, 0.42);
  height: 18rpx;
  width: 18rpx;
}

.habit-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.habit-card {
  align-items: center;
  background: rgba(255, 252, 246, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 34rpx;
  box-shadow: 0 22rpx 58rpx rgba(69, 54, 36, 0.1);
  display: flex;
  justify-content: space-between;
  padding: 24rpx;
}

.habit-card.is-done {
  background: linear-gradient(135deg, rgba(238, 255, 249, 0.96), rgba(247, 246, 255, 0.96));
}

.habit-left {
  align-items: center;
  display: flex;
  min-width: 0;
}

.habit-ring {
  align-items: center;
  border: 3rpx solid;
  border-radius: 32rpx;
  display: flex;
  height: 104rpx;
  justify-content: center;
  margin-right: 22rpx;
  width: 104rpx;
}

.icon {
  align-items: center;
  border-radius: 24rpx;
  display: flex;
  font-size: 42rpx;
  height: 82rpx;
  justify-content: center;
  width: 82rpx;
}

.habit-copy {
  min-width: 0;
}

.habit-name {
  color: #171a33;
  font-size: 32rpx;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.habit-meta {
  color: #827d76;
  font-size: 24rpx;
}

.dot {
  margin: 0 8rpx;
}

.record-button {
  background: #15172f;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 66rpx;
  margin: 0;
  min-width: 132rpx;
}

.done-pill {
  background: linear-gradient(135deg, rgba(33, 182, 168, 0.18), rgba(108, 99, 255, 0.14));
  border-radius: 999rpx;
  color: #14927f;
  font-size: 25rpx;
  font-weight: 900;
  padding: 16rpx 20rpx;
}

.encouragement-card {
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.82), rgba(255, 247, 229, 0.82));
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 28rpx;
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  position: relative;
  z-index: 1;
}

.encouragement-icon {
  align-items: center;
  background: #15172f;
  border-radius: 22rpx;
  color: #ffffff;
  display: flex;
  font-size: 34rpx;
  height: 72rpx;
  justify-content: center;
  width: 72rpx;
}

.encouragement-title {
  color: #171a33;
  font-size: 26rpx;
  font-weight: 900;
  margin-bottom: 6rpx;
}

.encouragement-text {
  color: #7c746c;
  font-size: 24rpx;
  line-height: 1.45;
}

.habit-actions {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.action-row {
  display: flex;
  gap: 10rpx;
}

.text-action {
  background: rgba(21, 23, 47, 0.06);
  border-radius: 999rpx;
  color: #4d4f68;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
  margin: 0;
  min-width: 72rpx;
  padding: 0 16rpx;
}

.text-action.danger {
  background: rgba(217, 74, 74, 0.08);
  color: #d94a4a;
}

.swipe-row {
  border-radius: 34rpx;
  overflow: hidden;
  position: relative;
}

.swipe-row .habit-card {
  position: relative;
  transform: translateX(0);
  transition: transform 0.22s ease;
  z-index: 2;
}

.swipe-row.is-open .habit-card {
  transform: translateX(-184rpx);
}

.swipe-actions {
  bottom: 0;
  display: flex;
  justify-content: flex-end;
  position: absolute;
  right: 0;
  top: 0;
  width: 216rpx;
  z-index: 1;
}

.swipe-action {
  align-items: center;
  border-radius: 0;
  color: #ffffff;
  display: flex;
  font-size: 26rpx;
  font-weight: 900;
  justify-content: center;
  line-height: 1;
  margin: 0;
  padding: 0;
  width: 108rpx;
}

.swipe-action.undo {
  background: #7f8497;
}

.swipe-action.delete {
  background: #d94a4a;
}

.tap-hint {
  color: #aaa49c;
  font-size: 21rpx;
  margin-top: 8rpx;
}

/* Compact interaction polish: keep actions discoverable without visual noise. */
.quick-grid {
  grid-template-columns: 1fr 1fr 0.8fr;
}

.quick-add.compact {
  background: rgba(21, 23, 47, 0.08);
  border: 1rpx solid rgba(21, 23, 47, 0.08);
  box-shadow: none;
  color: #202033;
  font-size: 24rpx;
  min-height: 86rpx;
  padding: 0 12rpx;
}

.record-button {
  align-items: center;
  background: linear-gradient(135deg, #15172f, #2e335f);
  border-radius: 50%;
  box-shadow: 0 12rpx 24rpx rgba(21, 23, 47, 0.16);
  display: flex;
  font-size: 28rpx;
  height: 64rpx;
  justify-content: center;
  line-height: 64rpx;
  min-width: 64rpx;
  padding: 0;
  width: 64rpx;
}

.habit-card {
  min-height: 116rpx;
  padding: 22rpx 20rpx;
}

.habit-actions {
  min-width: 72rpx;
}
