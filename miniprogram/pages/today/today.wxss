.hero {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(238, 245, 255, 0.76));
  margin-bottom: 34rpx;
  overflow: hidden;
}

.hero-bg {
  background: linear-gradient(135deg, rgba(108, 99, 255, 0.18), rgba(33, 182, 168, 0.16));
  border-radius: 50%;
  height: 280rpx;
  position: absolute;
  right: -86rpx;
  top: -98rpx;
  width: 280rpx;
}

.hero-top {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
  position: relative;
}

.eyebrow {
  color: #6c63ff;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
  line-height: 1.16;
  margin-bottom: 12rpx;
  max-width: 500rpx;
}

.add-button {
  align-items: center;
  background: rgba(32, 32, 51, 0.92);
  border-radius: 50%;
  box-shadow: 0 18rpx 38rpx rgba(32, 32, 51, 0.22);
  color: #ffffff;
  display: flex;
  font-size: 42rpx;
  height: 92rpx;
  justify-content: center;
  line-height: 92rpx;
  margin: 0;
  padding: 0;
  width: 92rpx;
}

.progress-wrap {
  margin-top: 42rpx;
  position: relative;
}

.progress-info {
  color: #4d4f68;
  display: flex;
  font-size: 26rpx;
  font-weight: 800;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.progress-track {
  background: rgba(108, 99, 255, 0.12);
  border-radius: 999rpx;
  height: 18rpx;
  overflow: hidden;
}

.progress-bar {
  background: linear-gradient(90deg, #6c63ff, #21b6a8);
  border-radius: 999rpx;
  height: 100%;
  transition: width 0.25s ease;
}

.hero-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 26rpx;
  position: relative;
}

.section-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 8rpx 4rpx 22rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 36rpx;
  font-weight: 900;
  margin-bottom: 6rpx;
}

.pulse-dot {
  background: #21b6a8;
  border-radius: 50%;
  box-shadow: 0 0 0 12rpx rgba(33, 182, 168, 0.12);
  height: 18rpx;
  width: 18rpx;
}

.habit-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.habit {
  align-items: center;
  display: flex;
  justify-content: space-between;
  overflow: hidden;
  padding-left: 34rpx;
}

.habit-accent {
  bottom: 0;
  left: 0;
  position: absolute;
  top: 0;
  width: 8rpx;
}

.habit.is-done {
  background: rgba(245, 252, 248, 0.9);
}

.habit-main {
  align-items: center;
  display: flex;
  min-width: 0;
}

.icon {
  align-items: center;
  border-radius: 28rpx;
  display: flex;
  font-size: 42rpx;
  height: 92rpx;
  justify-content: center;
  margin-right: 22rpx;
  width: 92rpx;
}

.habit-copy {
  min-width: 0;
}

.habit-name {
  font-size: 32rpx;
  font-weight: 850;
  margin-bottom: 10rpx;
}

.habit-meta {
  color: #7f8094;
  font-size: 24rpx;
}

.dot {
  margin: 0 8rpx;
}

.record-button {
  font-size: 26rpx;
  line-height: 66rpx;
  margin: 0;
  min-width: 132rpx;
}

.done-pill {
  background: linear-gradient(135deg, rgba(33, 182, 168, 0.15), rgba(108, 99, 255, 0.12));
  border-radius: 999rpx;
  color: #14927f;
  font-size: 25rpx;
  font-weight: 800;
  padding: 16rpx 20rpx;
}
