.detail-shell {
  background: linear-gradient(180deg, #f7ead4 0%, #f5efe5 48%, #eef3ff 100%);
}

.detail-hero {
  align-items: center;
  display: flex;
  gap: 22rpx;
  margin-bottom: 24rpx;
}

.habit-icon {
  align-items: center;
  border-radius: 30rpx;
  display: flex;
  font-size: 52rpx;
  height: 112rpx;
  justify-content: center;
  width: 112rpx;
}

.eyebrow {
  color: #6c63ff;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.title {
  color: #171a33;
  font-size: 42rpx;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.summary-grid {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 24rpx;
}

.summary-value {
  color: #15172f;
  font-size: 52rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.summary-card.warning .summary-value {
  color: #d94a4a;
}

.chart-card,
.break-card {
  margin-bottom: 24rpx;
}

.section-title {
  color: #171a33;
  font-size: 34rpx;
  font-weight: 900;
  margin-bottom: 18rpx;
}

.legend-row {
  align-items: center;
  color: #827d76;
  display: flex;
  font-size: 22rpx;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.legend {
  border-radius: 50%;
  height: 16rpx;
  margin-left: 10rpx;
  width: 16rpx;
}

.legend.done,
.chart-day.done .bar {
  background: #21b6a8;
}

.legend.missed,
.chart-day.missed .bar {
  background: #f06c6c;
}

.legend.rest,
.chart-day.rest .bar {
  background: #d8d6d0;
}

.chart-grid {
  align-items: end;
  display: flex;
  gap: 8rpx;
  overflow-x: auto;
  padding-bottom: 6rpx;
}

.chart-day {
  align-items: center;
  display: flex;
  flex: 0 0 30rpx;
  flex-direction: column;
  gap: 8rpx;
}

.bar {
  border-radius: 999rpx;
  height: 88rpx;
  width: 18rpx;
}

.chart-day.rest .bar {
  height: 42rpx;
}

.day-label {
  color: #9b968e;
  font-size: 18rpx;
  transform: rotate(-45deg);
  white-space: nowrap;
}

.empty-copy,
.break-row {
  color: #827d76;
  font-size: 28rpx;
  padding: 16rpx 0;
}

.break-row {
  border-top: 1rpx solid rgba(21, 23, 47, 0.08);
}
