page {
  background: #f5efe5;
  color: #202033;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.container {
  min-height: 100vh;
  overflow: hidden;
  padding: 28rpx;
  position: relative;
}

.card {
  background: rgba(255, 252, 246, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 36rpx;
  box-shadow: 0 26rpx 70rpx rgba(69, 54, 36, 0.12);
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.primary-button {
  background: linear-gradient(135deg, #15172f 0%, #6c63ff 58%, #21b6a8 100%);
  border-radius: 999rpx;
  box-shadow: 0 18rpx 40rpx rgba(108, 99, 255, 0.28);
  color: #ffffff;
  font-weight: 800;
}

.muted {
  color: #827d76;
}

.glass-chip {
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  color: #4d4f68;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}
